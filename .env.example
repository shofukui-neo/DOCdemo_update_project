# DOCdemo 自動化システム 環境変数テンプレート
# このファイルを `.env` にコピーして実値を埋めてください
# `.env` は .gitignore 済み — コミットしないこと

# Brainverse 管理画面ログイン情報
DOCDEMO_LOGIN_EMAIL=
DOCDEMO_LOGIN_PASSWORD=

# ブラウザ表示モード（初回は false 推奨、安定後は true で高速バックグラウンド処理）
DOCDEMO_HEADLESS=false

# ログレベル: DEBUG / INFO / WARNING / ERROR
DOCDEMO_LOG_LEVEL=INFO
